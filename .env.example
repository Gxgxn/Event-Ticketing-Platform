# Rename to .env and fill in real values before running compose.
# DOMAIN: your sslip.io hostname = <your-droplet-ip>.sslip.io
DOMAIN=YOUR_DROPLET_IP.sslip.io

# Database
DB_USER=tickets_user
DB_PASSWORD=CHANGE_ME_strong_db_password

# Keycloak admin console login
KC_ADMIN=admin
KC_ADMIN_PASSWORD=CHANGE_ME_strong_admin_password
